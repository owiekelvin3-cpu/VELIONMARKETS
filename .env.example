VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Vercel Project Settings → Environment Variables ──────────────────────────
# Add the two VITE_* keys above for Production, Preview, and Development.
# Do NOT add SUPABASE_SERVICE_ROLE_KEY to Vercel (frontend-only deploy).

# Server-only: required for npm run create-admin (never expose in frontend)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional overrides for npm run create-admin
# ADMIN_EMAIL=admin@velionmarkets.com
# ADMIN_PASSWORD=

# Optional: POST client errors in production (Sentry ingest, custom endpoint, etc.)
# VITE_ERROR_REPORTING_URL=https://your-error-ingest-endpoint

# Web Push (optional — enables background push when the app is closed)
# Generate keys: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
# Set in Supabase Edge Function secrets: VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT=mailto:support@velionmarkets.com

# After deploy, add your Vercel domain(s) in Supabase:
# Authentication → URL Configuration → Site URL + Redirect URLs
# Example: https://your-app.vercel.app and https://velionmarkets.com

# For Supabase MCP in Cursor (.cursor/mcp.json), create a Personal Access Token at:
# https://supabase.com/dashboard/account/tokens
